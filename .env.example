# GASE Configuration - Copy to .env and customize

# Logging
LOG_LEVEL=INFO

# Data directory
DATA_DIR=data

# Embedding Model
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Qdrant Vector Store
QDRANT_MODE=memory
QDRANT_HOST=localhost
QDRANT_PORT=6333

# BM25 Keyword Search
BM25_LANGUAGE=english

# Fusion Algorithm Weights
FUSION_ALPHA=0.4
FUSION_BETA=0.4
FUSION_GAMMA=0.2

# Parsing
PARSING_CHUNK_SIZE=512
PARSING_OCR_ENABLED=false

# Optional: Ollama embeddings (if you want to use local LLM instead of sentence-transformers)
# EMBEDDING_MODE=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
